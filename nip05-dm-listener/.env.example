# Required — Jorgenclaw's Nostr identity
JORGENCLAW_NSEC=nsec1...

# Required — Cloudflare KV for NIP-05 registry
CF_API_TOKEN=your_cloudflare_api_token
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_KV_NAMESPACE_ID=your_kv_namespace_id

# Required — NWC connection string (or set NWC_CONFIG_PATH to a JSON file)
NWC_CONNECTION_STRING=nostr+walletconnect://WALLET_PUBKEY?relay=wss://relay.example.com&secret=HEX_SECRET

# Optional — override defaults
# RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band
# PRICE_SATS=1000
# PAYMENT_TIMEOUT_MS=600000
